{
  "version": 2,
  "buildCommand": "sh ./build-vercel.sh",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/claude",
      "dest": "/api/claude.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
