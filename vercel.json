{
  "version": 2,
  "buildCommand": "bash build-vercel.sh",
  "outputDirectory": "public",
  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
